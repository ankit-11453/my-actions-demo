    {
      "name": "User request",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const timestamp = Date.now();\r",
              "pm.variables.set(\"name\", \"User_\" + timestamp);\r",
              "pm.variables.set(\"email\", \"user_\" + timestamp + \"@test.com\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Create user response is valid\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.be.an(\"object\");\r",
              "    pm.expect(jsonData.id).to.exist;\r",
              "    pm.expect(jsonData.name).to.eql(pm.variables.get(\"name\"));\r",
              "    pm.expect(jsonData.email).to.eql(pm.variables.get(\"email\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Store user id for next requests\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.collectionVariables.set(\"user_id\", jsonData.id);\r",
              "    pm.collectionVariables.set(\"created_email\", jsonData.email);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"{{name}}\",\r\n  \"email\": \"{{email}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get User request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Fetched user matches created user\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.eql(pm.collectionVariables.get(\"user_id\"));\r",
              "    pm.expect(jsonData.email).to.eql(pm.collectionVariables.get(\"created_email\"));\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"Ravi Kumar\",\r\n  \"age\": 31,\r\n  \"email\": \"ravi.kumar@test.com\"\r\n}"
        },
        "url": {
          "raw": "{{base_url}}/users/{{user_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "{{user_id}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List Users request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is an array\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"Created user exists in list\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    const userId = pm.collectionVariables.get(\"user_id\");\r",
              "    const found = jsonData.some(u => String(u.id) === String(userId));\r",
              "    pm.expect(found).to.be.true;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
